# ──────────────────────────────────────────────────────────────────────────
# SajiloKirana backend — environment template.
# Copy to .env (dev), .env.staging, .env.prod. NEVER commit the real .env files.
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000

# Database (Prisma). Format: postgresql://USER:PASS@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://sajilo:sajilo@localhost:5432/sajilokirana?schema=public"

# Redis (dispatch confirm-window timers + caching)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# OTP — in dev, OTP code is logged to the console and fixed to 123456.
# In prod this is sent via SMS; set USE_FIXED_OTP=false.
OTP_USE_FIXED=true
OTP_FIXED_CODE="123456"
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=30

# Dispatch engine
DISPATCH_CONFIRM_WINDOW_SECONDS=40
DISPATCH_INITIAL_RADIUS_KM=2
DISPATCH_EXPANDED_RADIUS_KM=5
DISPATCH_TOP_N_CANDIDATES=3

# ML service (internal HTTP — Part E). Optional in Phase 0/1.
ML_SERVICE_URL="http://localhost:8000"

# Integrations (Part D.5) — fill from vendor docs before going live.
# Sparrow SMS (Nepal) — https://api.sparrowsms.com
SPARROW_SMS_TOKEN=""
SPARROW_SMS_FROM=""
# Twilio (WhatsApp fallback)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# Payments (Part D.5) — stubs until live docs confirmed.
ESEWA_MERCHANT_ID=""
ESEWA_SECRET=""
KHALTI_SECRET_KEY=""
FONEPAY_MERCHANT_ID=""
FONEPAY_PASSWORD=""

# FCM (push, all three apps)
FCM_SERVER_KEY=""
